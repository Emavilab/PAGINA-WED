# ============================================================
# GITIGNORE - Archivos que NO deben subirse a Git
# ============================================================

# ============================================================
# ARCHIVOS DE CONFIGURACIÓN SENSIBLES
# ============================================================
.env
.env.local
.env.*.local

# ============================================================
# CREDENCIALES Y SECRETOS
# ============================================================
config/credentials.php
config/secrets.php
core/smtp_password.php

# ============================================================
# ARCHIVOS DEL SISTEMA
# ============================================================
.DS_Store
Thumbs.db
*.bak
*.backup
*.swp
*.swo
*~
*.log

# ============================================================
# IDE Y EDITORES
# ============================================================
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
.VSCodeCounter/
.vs/
.classpath
.project
.settings/

# ============================================================
# DIRECTORIOS DE DEPENDENCIAS
# ============================================================
vendor/
node_modules/
composer.lock

# ============================================================
# DIRECTORIOS DE UPLOADS (OPCIONAL)
# ============================================================
# Descomenta si deseas que uploads no se versionen
# img/productos/*
# img/bancos/*
# img/banners/*
# img/slides/*

# ============================================================
# ARCHIVOS DE CACHÉ
# ============================================================
cache/
.cache/
*.cache
temp/
tmp/

# ============================================================
# DIRECTORIOS DE SESIONES (si se almacenan en archivos)
# ============================================================
sessions/

# ============================================================
# ARCHIVOS DE DATABASE (para desarrollo local)
# ============================================================
*.sql.bak
database/*.sql.backup
dumps/

# ============================================================
# COMPILADOS Y HERRAMIENTAS BUILD
# ============================================================
dist/
build/
.env.build

# ============================================================
# HERRAMIENTAS DE TESTING
# ============================================================
coverage/
.phpunit.result.cache
