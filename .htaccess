# ============================================================
# HTACCESS - PROTECCIONES DE SEGURIDAD (RAÍZ)
# ============================================================
# Sintaxis para Apache 2.4+

# Bloquear acceso directo a archivos sensibles
<FilesMatch "\.env">
    Require all denied
</FilesMatch>

<FilesMatch "\.git">
    Require all denied
</FilesMatch>

# Permitir acceso normal a todos los demás archivos
<FilesMatch "\.php$">
    Require all granted
</FilesMatch>
